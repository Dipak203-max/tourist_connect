# TouristConnect Backend - Environment Variables Template
# Copy this to .env (if using a loader) or set in your system/CI environment.

# Database
DB_URL=jdbc:mysql://localhost:3306/tourist_connect?createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=your_secure_password

# Mail (Gmail App Password recommended)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Google OAuth 2.0
# Get this from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Khalti Payment
KHALTI_SECRET_KEY=your_khalti_secret_key
